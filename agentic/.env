# ============================================================
# .env.example — Copy to .env and fill in your values
# ============================================================
# HR EMPLOYEE MANAGEMENT AGENTIC SYSTEM
# Multi-Provider Support: Ollama → Groq → Gemini → OpenRouter
# ============================================================

# ── LLM Provider ─────────────────────────────────────────
# Options: "ollama" | "groq" | "gemini" | "openrouter"
# Fallback chain: Ollama (local) → Groq → Gemini → OpenRouter
LLM_PROVIDER=ollama

# ════════════════════════════════════════════════════════════
# OLLAMA CONFIG (Primary - Local, No API Key Required)
# ════════════════════════════════════════════════════════════
OLLAMA_BASE_URL=http://localhost:11434

# Multi-Model Configuration (Recommended for HR System):
#   Planner  = qwen2.5-coder:1.5b  (fast structured planning)
#   Executor = nemotron-mini       (tool execution, 4B params)
#   Reflector= nemotron-mini       (quality evaluation)
#
# Pull commands:
#   ollama pull qwen2.5-coder:1.5b
#   ollama pull nemotron-mini
#   ollama pull granite3.1-moe:3b   (alternative executor)

OLLAMA_MODEL=nemotron-mini
OLLAMA_PLANNER_MODEL=qwen2.5-coder:1.5b
OLLAMA_EXECUTOR_MODEL=nemotron-mini
OLLAMA_REFLECTOR_MODEL=nemotron-mini

# Role aliases (optional - used if per-agent not set)
OLLAMA_FAST_MODEL=qwen2.5-coder:1.5b
OLLAMA_QUALITY_MODEL=nemotron-mini
OLLAMA_CODER_MODEL=qwen2.5-coder:1.5b

# ════════════════════════════════════════════════════════════
# GROQ CONFIG (Cloud Backup - Fast, Requires API Key)
# ════════════════════════════════════════════════════════════
# Get keys at: https://console.groq.com/keys
# Provide 1-8 keys for round-robin rotation (increases rate limits)
# GROQ_KEYS=gsk_key1,gsk_key2,gsk_key3,gsk_key4

# Groq model overrides (optional)
GROQ_PLANNER_MODEL=llama-3.3-70b-versatile
GROQ_EXECUTOR_MODEL=llama-3.3-70b-versatile
GROQ_REFLECTOR_MODEL=llama-3.3-70b-versatile

# ════════════════════════════════════════════════════════════
# GEMINI CONFIG (Google AI - Cloud Backup)
# ════════════════════════════════════════════════════════════
# Get key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model overrides (optional)
GEMINI_PLANNER_MODEL=gemini-2.0-flash-lite
GEMINI_EXECUTOR_MODEL=gemini-2.0-flash-lite
GEMINI_REFLECTOR_MODEL=gemini-2.0-flash

# ════════════════════════════════════════════════════════════
# OPENROUTER CONFIG (Universal API - Cloud Backup)
# ════════════════════════════════════════════════════════════
# Get key at: https://openrouter.ai/keys
# Supports: NVIDIA, Anthropic, OpenAI, Google, Meta models
# OPENROUTER_API_KEY=sk-or-v1-your_key_here

# OpenRouter model overrides (optional)
# NVIDIA Nemotron models recommended for consistency with local setup
OPENROUTER_PLANNER_MODEL=nvidia/llama-3.1-nemotron-70b
OPENROUTER_EXECUTOR_MODEL=nvidia/llama-3.1-nemotron-70b
OPENROUTER_REFLECTOR_MODEL=nvidia/llama-3.1-nemotron-70b

# ════════════════════════════════════════════════════════════
# PROJECT IDENTITY (HR Employee Management System)
# ════════════════════════════════════════════════════════════
PROJECT_NAME=NexaWorks HRMS
PROJECT_DESCRIPTION=AI-powered Employee Management System with natural language queries and HR review workflows
PROJECT_URL=http://localhost:5173

# ════════════════════════════════════════════════════════════
# SYSTEM PROMPT (HR Domain)
# ════════════════════════════════════════════════════════════
SYSTEM_PROMPT=You are an HR Assistant AI for NexaWorks employee management. Your role is to help HR staff with employee-related tasks. When searching employees, provide natural language summaries with clear, readable formatting - never raw SQL or database dumps. When adding employees, ALWAYS use the hr_employee_add_draft skill to create a draft for HR review - never execute database writes directly. Always ask for missing required information. Be concise but thorough. Format employee data in tables or bulleted lists for readability.

# ════════════════════════════════════════════════════════════
# AGENT TEMPERATURES ────────────────────────────────────────
PLANNER_TEMP=0.3
EXECUTOR_TEMP=0.1
REFLECTOR_TEMP=0.2

# ════════════════════════════════════════════════════════════
# EXECUTION LIMITS ─────────────────────────────────────────
MAX_ITERATIONS=10
MAX_REFLECTION_LOOPS=3

# ════════════════════════════════════════════════════════════
# MEMORY / EMBEDDINGS ───────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_TOP_K=5

# ════════════════════════════════════════════════════════════
# SERVER CONFIG ──────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# ════════════════════════════════════════════════════════════
# GLM-OCR VISION TOOL (Document/Image Extraction)
# ════════════════════════════════════════════════════════════
# Used ONLY for OCR - NOT the reasoning LLM
GLM_OCR_ENABLED=true
GLM_OCR_MODE=ollama
GLM_OCR_OLLAMA_MODEL=glm4v
# GLM_OCR_URL=http://localhost:7860
GLM_OCR_TIMEOUT=60

# ════════════════════════════════════════════════════════════
# CONTEXT WINDOW SIZES (Adjust based on your hardware)
# ════════════════════════════════════════════════════════════
# Increase if you get truncation errors
# Decrease if you get OOM/slow responses on low-RAM machines
CONTEXT_PLANNER=4096
CONTEXT_EXECUTOR=8192
CONTEXT_REFLECTOR=4096
CONTEXT_MAX=16384

# ════════════════════════════════════════════════════════════
# DATABASE (SQLite default)
# ════════════════════════════════════════════════════════════
# DB_URL=sqlite:///./memory/json/agent.db
# DB_ECHO=false
# DB_POOL_SIZE=5
