{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        }
    },
    "builds": [
        {
            "src": "backend/**/*.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "backend/data/**/*.db",
                    "backend/*.db"
                ]
            }
        }
    ]
}
